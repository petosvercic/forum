+
+/* --- Full-screen HUD overlay helpers (scanline + tiny flicker) --- */
+.viora-scanline {
+  position: fixed;
+  left: 0;
+  right: 0;
+  top: -25vh;
+  height: 2px;
+  pointer-events: none;
+  z-index: 6;
+  opacity: 0.9;
+  background: linear-gradient(90deg, rgba(0, 0, 0, 0), rgba(0, 220, 255, 0.28), rgba(190, 120, 255, 0.18), rgba(0, 0, 0, 0));
+  box-shadow: 0 0 28px rgba(0, 220, 255, 0.14);
+  mix-blend-mode: screen;
+  animation: viora-scan 6.5s linear infinite;
+}
+
+@keyframes viora-scan {
+  0% { transform: translate3d(0, -25vh, 0); }
+  100% { transform: translate3d(0, 140vh, 0); }
+}
+
+.viora-flicker {
+  position: fixed;
+  inset: 0;
+  pointer-events: none;
+  z-index: 5;
+  opacity: 0.10;
+  background-image:
+    repeating-linear-gradient(0deg, rgba(255, 255, 255, 0.04) 0 1px, rgba(0, 0, 0, 0) 1px 3px),
+    radial-gradient(60% 50% at 50% 20%, rgba(0, 220, 255, 0.06), rgba(0, 0, 0, 0) 60%);
+  mix-blend-mode: overlay;
+  animation: viora-flicker 8.5s ease-in-out infinite;
+}
+
+@keyframes viora-flicker {
+  0%, 100% { opacity: 0.08; }
+  48% { opacity: 0.12; }
+  52% { opacity: 0.06; }
+  74% { opacity: 0.11; }
+}
+
+@media (prefers-reduced-motion: reduce) {
+  .viora-bg::after,
+  .viora-float,
+  .viora-scanline,
+  .viora-flicker {
+    animation: none !important;
+  }
+}
