diff --git a/app/globals.css b/app/globals.css
index 111aaaa..222bbbb 100644
--- a/app/globals.css
+++ b/app/globals.css
@@ -1,3 +1,4 @@
 @tailwind base;
 @tailwind components;
 @tailwind utilities;
@@
 .dark .viora-panel {
   background: rgba(10, 10, 10, 0.55);
   border-color: rgba(255,255,255,0.12);
 }
+
+/* ===== V4: HUD / grid / noise / scanline ===== */
+.viora-bg{
+  position: relative;
+  isolation: isolate;
+  background-color: rgb(5,7,12);
+  background-image:
+    radial-gradient(60% 50% at 18% 18%, rgba(0,220,255,0.18) 0%, rgba(0,0,0,0) 62%),
+    radial-gradient(55% 45% at 82% 26%, rgba(168,120,255,0.16) 0%, rgba(0,0,0,0) 64%),
+    radial-gradient(60% 60% at 50% 92%, rgba(255,180,80,0.10) 0%, rgba(0,0,0,0) 70%),
+    url("/viora-bg.webp");
+  background-size: cover;
+  background-position: center;
+  background-attachment: fixed;
+}
+.viora-bg::before{
+  content:"";
+  position:absolute;
+  inset:0;
+  pointer-events:none;
+  z-index:0;
+  opacity: .14;
+  background-image:
+    linear-gradient(to right, rgba(0,220,255,0.18) 1px, transparent 1px),
+    linear-gradient(to bottom, rgba(168,120,255,0.12) 1px, transparent 1px);
+  background-size: 72px 72px;
+  mask-image: radial-gradient(ellipse at 50% 40%, black 0%, rgba(0,0,0,0) 70%);
+}
+.viora-bg::after{
+  content:"";
+  position:absolute;
+  inset:-20%;
+  pointer-events:none;
+  z-index:0;
+  opacity:.22;
+  background-image:
+    radial-gradient(circle at 20% 30%, rgba(0,220,255,0.20) 0%, rgba(0,0,0,0) 45%),
+    radial-gradient(circle at 80% 35%, rgba(168,120,255,0.16) 0%, rgba(0,0,0,0) 48%),
+    linear-gradient(120deg, rgba(255,180,80,0.12) 0%, rgba(0,0,0,0) 35%, rgba(0,220,255,0.10) 65%, rgba(0,0,0,0) 100%);
+  filter: blur(18px);
+  animation: viora-drift 14s ease-in-out infinite;
+}
+@keyframes viora-drift{
+  0%{ transform: translate3d(-1.5%, -1%, 0) }
+  50%{ transform: translate3d(1.5%, 1%, 0) }
+  100%{ transform: translate3d(-1.5%, -1%, 0) }
+}
+.viora-hud{
+  opacity:.26;
+  mix-blend-mode: screen;
+  background-image:
+    radial-gradient(circle at 50% 50%, rgba(0,220,255,0.20) 0 1px, transparent 2px),
+    radial-gradient(circle at 50% 50%, transparent 0 120px, rgba(0,220,255,0.06) 121px 122px, transparent 123px),
+    linear-gradient(to right, rgba(0,220,255,0.22) 0 2px, transparent 2px 100%),
+    linear-gradient(to bottom, rgba(0,220,255,0.18) 0 2px, transparent 2px 100%),
+    linear-gradient(90deg, transparent 0 18px, rgba(168,120,255,0.20) 18px 19px, transparent 19px 100%),
+    linear-gradient(0deg, transparent 0 18px, rgba(255,180,80,0.16) 18px 19px, transparent 19px 100%);
+  background-size:
+    18px 18px,
+    100% 100%,
+    24px 100%,
+    100% 24px,
+    100% 100%,
+    100% 100%;
+  background-position:
+    0 0,
+    50% 50%,
+    0 0,
+    0 0,
+    0 0,
+    0 0;
+}
+.viora-scanline{
+  opacity:.10;
+  background: repeating-linear-gradient(
+    to bottom,
+    rgba(255,255,255,0.00) 0px,
+    rgba(255,255,255,0.00) 6px,
+    rgba(255,255,255,0.08) 7px
+  );
+  animation: viora-scan 10s linear infinite;
+}
+@keyframes viora-scan{
+  0%{ transform: translateY(-20%) }
+  100%{ transform: translateY(20%) }
+}
+.viora-vignette{
+  background: radial-gradient(ellipse at 50% 40%, rgba(0,0,0,0) 0%, rgba(0,0,0,0.65) 78%, rgba(0,0,0,0.88) 100%);
+}
+
+/* Panel: gradient border glow */
+.viora-panel{
+  position: relative;
+  overflow: hidden;
+}
+.viora-panel::before{
+  content:"";
+  position:absolute;
+  inset:0;
+  pointer-events:none;
+  border-radius: inherit;
+  padding: 1px;
+  background: linear-gradient(120deg, rgba(0,220,255,0.40), rgba(168,120,255,0.28), rgba(255,180,80,0.20));
+  -webkit-mask:
+    linear-gradient(#000 0 0) content-box,
+    linear-gradient(#000 0 0);
+  -webkit-mask-composite: xor;
+  mask-composite: exclude;
+  opacity:.55;
+}
+.viora-title{
+  background: linear-gradient(90deg, rgba(0,220,255,0.95), rgba(168,120,255,0.95), rgba(255,180,80,0.90));
+  -webkit-background-clip: text;
+  background-clip: text;
+  color: transparent;
+}
+@media (prefers-reduced-motion: reduce){
+  .viora-bg::after, .viora-scanline{ animation: none !important; }
+}
